# ============================================
# TRUSTEDGE — Environment Configuration
# Copy this file to .env and fill in values
# ============================================

# Server
NODE_ENV=development
PORT=5000

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/trustedge_db?schema=public"

# JWT Secrets (generate strong random strings for production)
JWT_ACCESS_SECRET=trustedge-access-secret-change-me-in-production
JWT_REFRESH_SECRET=trustedge-refresh-secret-change-me-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Logging
LOG_LEVEL=debug

# CORS
CORS_ORIGIN=http://localhost:5173
